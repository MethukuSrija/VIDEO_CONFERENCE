.env.example (root)
# ==========================================
# LiveMeet Platform - Environment Variables
# Copy this file to .env and fill in values
# ==========================================

# ===== Required =====
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===== Optional (for Google OAuth) =====
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== Auto-configured (override only if needed) =====
# Backend
JWT_SECRET=change-this-to-a-random-secret-key
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secretkey123456789abcdefghijklmnop
DATABASE_URL=postgresql+asyncpg://meetuser:meetpass@localhost:5432/meetplatform
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# ===== Future Production =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# RECORDING_S3_BUCKET=
.env (root - YOUR ACTUAL VALUES)
# ⚠️ FILL IN YOUR ACTUAL VALUES BELOW ⚠️

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-PASTE-YOUR-KEY-HERE

# Optional: Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=paste-your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=paste-your-client-secret-here

# These can stay as defaults
JWT_SECRET=change-this-to-a-random-secret-key-in-production
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secretkey123456789abcdefghijklmnop
DATABASE_URL=postgresql+asyncpg://meetuser:meetpass@localhost:5432/meetplatform
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_API_URL=http://localhost:8000
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_GOOGLE_CLIENT_ID=
